{
  "Test module": {
    "prefix": "tm",
    "body": [
      "#[cfg(test)]",
      "mod tests {",
      "\tuse super::*;",
      "",
      "\t#[test]",
      "\tfn test_nothing() {",
      "\t\t${1:assert_eq!(1 + 1, 2);}",
      "\t}",
      "}"
    ]
  },
  "Test function": {
    "prefix": "tf",
    "body": [
      "#[test]",
      "fn test_nothing() {",
      "\t${1:assert_eq!(1 + 1, 2);}",
      "}"
    ]
  },
  "#[cfg(...)]": {
    "prefix": "cf",
    "body": "#[cfg(${1:feature = \"xxx\"})]"
  },
  "#[cfg(feature = \"...\")]": {
    "prefix": "cff",
    "body": "#[cfg(feature = \"${1:xxx}\")]"
  },
  "format!(...)": {
    "prefix": "fo",
    "body": "format!(\"{:?}\", ${1});"
  },
  "println!(...)": {
    "prefix": "pr",
    "body": "println!(\"{:?}\", ${1});"
  },
  "Derive basic": {
    "prefix": "de",
    "body": "#[derive(Debug, Clone)]"
  },
  "Derive serde": {
    "prefix": "ds",
    "body": "#[derive(Debug, Clone, Serialize, Deserialize)]"
  },
  "anyhow::Result<...>": {
    "prefix": "are",
    "body": "anyhow::Result<${1:()}>"
  }
}
